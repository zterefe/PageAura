{
  "manifest_version": 3,
  "name": "PageAura",
  "description": "PageAura extension scaffold for local development.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "action": {
    "default_title": "PageAura",
    "default_popup": "popup/index.html"
  },
  "options_page": "options/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
