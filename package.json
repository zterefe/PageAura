{
  "name": "pageaura",
  "private": true,
  "version": "0.1.0",
  "description": "PageAura public monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @pageaura/shared-types -w @pageaura/dom-snapshot -w @pageaura/validator -w @pageaura/extension",
    "build:extension": "npm run build -w @pageaura/extension",
    "dev:extension": "npm run dev -w @pageaura/extension",
    "typecheck": "npm run typecheck -ws",
    "lint": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml}\"",
    "release:zip": "node ./scripts/release-zip.mjs",
    "version:check": "node ./scripts/maintenance/check-extension-version.mjs",
    "version:bump": "node ./scripts/maintenance/bump-version.mjs",
    "changelog:check": "node -e \"const fs=require('fs');const c=fs.readFileSync('CHANGELOG.md','utf8');if(!c.includes('## [Unreleased]')){console.error('Missing Unreleased section in CHANGELOG.md');process.exit(1)};console.log('CHANGELOG.md contains Unreleased section');\"",
    "maintenance:release": "npm run version:check && npm run changelog:check && npm run build:extension && npm run release:zip"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
